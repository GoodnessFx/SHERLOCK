# Anthropic Claude API
ANTHROPIC_API_KEY=your_key_here

# Polymarket (no auth needed for read-only, but add if you have CLOB access)
POLYMARKET_API_KEY=optional

# Signals
OPENWEATHER_API_KEY=your_key_here    # free tier, 1000 calls/day
NEWS_API_KEY=your_key_here           # free tier, newsapi.org
COINGECKO_API_KEY=optional           # free tier works without key

# Monetization
SOLANA_WALLET_ADDRESS=your_wallet_here

# Server
API_PORT=8000
API_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Agent Behavior
DAEMON_INTERVAL_MINUTES=15
MIN_EDGE_THRESHOLD=0.05              # 5% minimum edge to report
MIN_CONFIDENCE_THRESHOLD=0.50
MAX_MARKETS_PER_RUN=20
MEMORY_RECALL_COUNT=5

# Database
SQLITE_DB_PATH=data/oracle.db
CHROMA_DB_PATH=data/chroma
